# ============================================================
# BEAN — Life Intelligence Platform
# Environment Variables Example
# Copy this file to .env and fill in your values
# ============================================================

# ----- Application -----
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=BEAN

# ----- Database (PostgreSQL) -----
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=postgresql://bean_user:bean_password@localhost:5432/bean_db

# ----- OpenAI -----
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_MODEL=gpt-4-turbo-preview
OPENAI_MAX_TOKENS=2048

# ----- Authentication (NextAuth / Clerk) -----
NEXTAUTH_SECRET=your-nextauth-secret-here
NEXTAUTH_URL=http://localhost:3000

# ----- AI Engine Service (Python FastAPI — future) -----
AI_ENGINE_URL=http://localhost:8000
AI_ENGINE_API_KEY=your-ai-engine-api-key

# ----- Azure (Production) — optional -----
# AZURE_CLIENT_ID=
# AZURE_CLIENT_SECRET=
# AZURE_TENANT_ID=
# AZURE_STORAGE_CONNECTION_STRING=

# ----- Monitoring — optional -----
# SENTRY_DSN=
# NEXT_PUBLIC_POSTHOG_KEY=
