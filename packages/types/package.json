{
  "name": "@bean/types",
  "version": "0.1.0",
  "private": true,
  "description": "Shared TypeScript types for BEAN platform",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "import": "./src/index.ts",
      "require": "./src/index.ts",
      "types": "./src/index.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "type-check": "tsc --noEmit",
    "dev": "echo '@bean/types: using source via transpilePackages'"
  },
  "devDependencies": {
    "typescript": "^5.4.0"
  }
}
