generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

// ─── Users ────────────────────────────────────────────────────────────
model User {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  email     String   @unique
  name      String?
  avatarUrl String?  @map("avatar_url")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  dimensionInputs DimensionInput[]
  lifeStates      LifeState[]
  lifeEvents      LifeEvent[]

  @@map("users")
}

// ─── Dimensions ───────────────────────────────────────────────────────
model Dimension {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  name        String   @unique
  label       String
  category    String
  description String
  sortOrder   Int      @default(0) @map("sort_order")
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("dimensions")
}

// ─── DimensionInput ───────────────────────────────────────────────────
model DimensionInput {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  userId    String   @db.ObjectId @map("user_id")
  inputType String   @map("input_type")
  valueJson Json     @map("value_json")
  source    String   @default("manual")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id])

  @@map("dimension_inputs")
}

// ─── LifeState ────────────────────────────────────────────────────────
model LifeState {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  userId      String   @db.ObjectId @map("user_id")
  lifeScore   Float    @map("life_score")
  timestamp   DateTime @default(now())
  triggeredBy String?  @map("triggered_by")
  notes       String?
  scores      DimensionScore[]

  user User @relation(fields: [userId], references: [id])

  @@map("life_states")
}

type DimensionScore {
  dimensionId String @db.ObjectId
  score       Float
  trend       String @default("stable")
  notes       String?
}

// ─── LifeEvent ────────────────────────────────────────────────────────
model LifeEvent {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  userId      String   @db.ObjectId @map("user_id")
  type        String
  title       String
  description String?
  date        DateTime
  impact      String?
  metadata    Json?
  createdAt   DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id])

  @@map("life_events")
}
